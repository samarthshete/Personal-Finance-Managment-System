# App environment: local | development | production
APP_ENV=local

# Security
SECRET_KEY=development_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (prefer DATABASE_URL in production)
DATABASE_URL=postgresql+asyncpg://budgetflow_user:budgetflow_password@localhost:5432/budgetflow_db
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=budgetflow_user
POSTGRES_PASSWORD=budgetflow_password
POSTGRES_DB=budgetflow_db

# Frontend / CORS
FRONTEND_URL=http://localhost:3000
# Comma-separated override. Leave blank to use environment defaults.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Object storage (MinIO locally, S3-compatible in production)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=budgetflow-reports
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false

# Advisor / OpenAI
ADVISOR_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Logging
LOG_LEVEL=INFO
